# Frontend (Expo) — copy to `.env` for production builds (gitignored).
# Run `npm run deploy:web` then upload dist/ to Namecheap public_html.

# Site origin (maps to backend APP_FRONTEND_URL)
EXPO_PUBLIC_APP_URL=https://pyonea.com

# API base (maps to backend APP_URL + /api/v1)
EXPO_PUBLIC_API_URL=https://api.pyonea.com/api/v1

# Public storage URL for product/seller images
EXPO_PUBLIC_IMAGE_BASE_URL=https://api.pyonea.com/storage

# Optional WebP resize proxy — not set in backend .env; add if you deploy one
EXPO_PUBLIC_IMAGE_PROXY_URL=

EXPO_PUBLIC_DEFAULT_PRODUCT_IMAGE=/placeholder-product.png

# Public site key only (backend RECAPTCHA_SITE_KEY — never copy RECAPTCHA_SECRET_KEY here)
EXPO_PUBLIC_RECAPTCHA_SITE_KEY=6Lf0iqgsAAAAAFLBjORhgqIsZTxy3msbo5k6totX

# Google OAuth web client (backend GOOGLE_CLIENT_ID)
# Google Cloud Console → Credentials → OAuth 2.0 Client → Authorized JavaScript origins:
#   https://pyonea.com, https://www.pyonea.com, http://localhost:8082
# Run: npm run verify:google-oauth
EXPO_PUBLIC_GOOGLE_CLIENT_ID=538453685845-chtpoo3e5mas6kbpp9nj1fjeq9e5slk1.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=538453685845-chtpoo3e5mas6kbpp9nj1fjeq9e5slk1.apps.googleusercontent.com

# Native Google Sign-In — create separate OAuth clients in Google Cloud Console
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Google Merchant / Customer Reviews (not in backend .env)
EXPO_PUBLIC_GOOGLE_MERCHANT_ID=5795794062

# GA4 — same property as legacy Pyonea web app (Search Console → Admin → Data streams)
EXPO_PUBLIC_GA_MEASUREMENT_ID=G-3G2ZPHGEV1

# Google Search Console → HTML tag method → paste content value only (not the full meta tag)
# Example: abc123token (from content="abc123token")
EXPO_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Skip product/blog/seller/category SSG during export (dev only — do not set in production)
# EXPO_PUBLIC_SKIP_DYNAMIC_SEO_EXPORT=1
